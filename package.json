{
  "name": "local-ai-support-bot",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:api": "pnpm --filter @local-ai-support-bot/api dev",
    "dev:web": "pnpm --filter @local-ai-support-bot/web dev",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "db:generate": "pnpm --filter @local-ai-support-bot/db prisma:generate",
    "db:migrate": "pnpm --filter @local-ai-support-bot/db prisma:migrate",
    "db:push": "pnpm --filter @local-ai-support-bot/db prisma:push",
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "pnpm db:generate && pnpm typecheck && pnpm test && pnpm build",
    "verify": "pnpm run ci",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.0",
    "@types/supertest": "^6.0.2",
    "husky": "^9.1.7",
    "supertest": "^7.0.0",
    "vitest": "^3.0.0"
  }
}
